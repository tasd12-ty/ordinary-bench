#!/bin/bash
# Qwen3.5-27B + ms-swift 版本锁定
# 所有版本均可通过环境变量覆盖，例如: SWIFT_VERSION=4.1.0 bash setup.sh

SWIFT_VERSION="${SWIFT_VERSION:-4.0.1}"
TRANSFORMERS_VERSION="${TRANSFORMERS_VERSION:-5.3.0}"
QWEN_VL_UTILS_VERSION="${QWEN_VL_UTILS_VERSION:-0.0.14}"
PEFT_VERSION="${PEFT_VERSION:-0.18.1}"
LIGER_KERNEL_VERSION="${LIGER_KERNEL_VERSION:-0.7.0}"
VLLM_VERSION="${VLLM_VERSION:-0.17.0}"
DEEPSPEED_VERSION="${DEEPSPEED_VERSION:-0.18.7}"

# git refs (可复现的 tag/commit hash)
FLA_GIT_REF="${FLA_GIT_REF:-v0.4.1}"
CAUSAL_CONV1D_GIT_REF="${CAUSAL_CONV1D_GIT_REF:-v1.6.1}"

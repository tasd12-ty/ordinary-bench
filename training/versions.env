#!/bin/bash
# Qwen3-VL-32B + verl v0.6.1 推荐版本

PYTHON_VERSION="${PYTHON_VERSION:-3.11}"
VERL_GIT_REF="${VERL_GIT_REF:-d62da49}"

# Linux + NVIDIA CUDA 12.8 推荐组合。若集群使用其他 CUDA 版本，请只改 INDEX_URL 与 torch 相关版本。
TORCH_INDEX_URL="${TORCH_INDEX_URL:-https://download.pytorch.org/whl/cu128}"
TORCH_VERSION="${TORCH_VERSION:-2.7.1}"
TORCHVISION_VERSION="${TORCHVISION_VERSION:-0.22.1}"

VLLM_VERSION="${VLLM_VERSION:-0.11.0}"
TRANSFORMERS_VERSION="${TRANSFORMERS_VERSION:-4.57.0}"
RAY_VERSION="${RAY_VERSION:-2.49.2}"
DATASETS_VERSION="${DATASETS_VERSION:-3.6.0}"
PANDAS_VERSION="${PANDAS_VERSION:-2.2.3}"
PYARROW_VERSION="${PYARROW_VERSION:-18.1.0}"
NUMPY_VERSION="${NUMPY_VERSION:-1.26.4}"
ACCELERATE_VERSION="${ACCELERATE_VERSION:-1.10.1}"
WANDB_VERSION="${WANDB_VERSION:-0.20.1}"
PILLOW_VERSION="${PILLOW_VERSION:-11.1.0}"
QWEN_VL_UTILS_VERSION="${QWEN_VL_UTILS_VERSION:-0.0.14}"

INSTALL_FLASH_ATTN="${INSTALL_FLASH_ATTN:-0}"
FLASH_ATTN_VERSION="${FLASH_ATTN_VERSION:-2.8.3}"
